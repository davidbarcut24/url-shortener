DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/urlshortener
REDIS_URL=redis://localhost:6379
BASE_URL=http://localhost:8000

# Comma-separated list of frontend origins allowed by CORS.
# In production set this to your deployed frontend URL only.
ALLOWED_ORIGINS=http://localhost:5173

# Secret used to HMAC-hash visitor IPs before they are stored.
# Generate a unique value with: openssl rand -hex 32
IP_HASH_SALT=CHANGE_ME_IN_PRODUCTION

# Short code generation
SHORT_CODE_LENGTH=7

# Redis TTL for cached URLs (seconds). Default: 86400 (24 hours).
DEFAULT_CACHE_TTL=86400

# Rate limiting: max requests per window (seconds) per IP.
RATE_LIMIT_SHORTEN=10
RATE_LIMIT_REDIRECT=60
RATE_LIMIT_WINDOW=60

# SQLAlchemy connection pool.
# pool_size + max_overflow = max simultaneous DB connections.
# Supabase/Neon free tier allows 15 — default 5+10 stays within that.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
